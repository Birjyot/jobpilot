# ─── JobPilot Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your actual values.
# This file is safe to commit — .env is gitignored.

# Database (defaults to local SQLite if not set)
DATABASE_URL=sqlite:///jobs.db

# Frontend URL (for short link generation)
FRONTEND_URL=http://localhost:3000

# ─── AI Provider Keys (at least one required for AI features) ─────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
